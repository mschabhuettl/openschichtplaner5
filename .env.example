# ==============================================================================
# OpenSchichtplaner5 — Konfiguration
# Kopiere diese Datei nach .env und passe die Werte an:
#   cp .env.example .env
#
# Wird verwendet von:
#   - start.sh  (lokale Entwicklung ohne Docker)
#   - docker compose up  (Docker-Betrieb)
# ==============================================================================

# ------------------------------------------------------------------------------
# Datenbank (Pflicht)
# ------------------------------------------------------------------------------
# Pfad zum SP5-Datenbankverzeichnis (die .DBF-Dateien).
# Unausgefüllt gelten die Defaults:
#   - Lokal (start.sh):  ../sp5_db/Daten neben dem Repo. Relative Pfade werden
#     von start.sh relativ zum Repo-Root aufgelöst (cwd-unabhängig).
#   - Docker:            /app/data (Named Volume sp5_data; DBFs im Volume-Root)
# Achtung: dieselbe .env wird von start.sh UND docker compose gelesen — ein
# Host-Pfad hier gilt im Container nicht. Für Docker den Wert leer lassen oder
# /app/data verwenden.
# SP5_DB_PATH=

# ------------------------------------------------------------------------------
# Sicherheit
# ------------------------------------------------------------------------------
# JWT-Signierungsschlüssel — UNBEDINGT ändern!
# Generieren: python3 -c "import secrets; print(secrets.token_hex(32))"
# Oder:       openssl rand -hex 32
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# Erlaubte CORS-Origins (kommagetrennt, kein Leerzeichen)
# Produktion: nur die echte Domain eintragen, z.B. https://sp5.example.com
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:5173

# HSTS-Header — NUR aktivieren wenn HTTPS via Reverse-Proxy vorhanden!
SP5_HSTS=false

# Dev-Modus — NIEMALS in Produktion aktivieren!
# Erlaubt den __dev_mode__ Token für Tests und den Role-Switcher.
SP5_DEV_MODE=false

# ------------------------------------------------------------------------------
# Server
# ------------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# Debug: true aktiviert Auto-Reload (nur für Entwicklung!)
DEBUG=false

# JWT-Token Gültigkeit in Stunden
TOKEN_EXPIRE_HOURS=8

# ------------------------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------------------------
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_API=200/minute
BRUTE_FORCE_MAX_ATTEMPTS=5
BRUTE_FORCE_LOCKOUT_MINUTES=15

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO
# Docker: /app/logs/sp5-api.log  |  Lokal: ./logs/sp5-api.log
LOG_FILE=./logs/sp5-api.log

# ------------------------------------------------------------------------------
# Docker / nginx (Production)
# ------------------------------------------------------------------------------
# Domain for the application (used in nginx config and certbot)
SP5_DOMAIN=meine-domain.de

# Exposed ports on the host (change if 80/443 are already in use)
SP5_HTTP_PORT=80
SP5_HTTPS_PORT=443

# ------------------------------------------------------------------------------
# Session
# ------------------------------------------------------------------------------
SESSION_CLEANUP_INTERVAL_MINUTES=60

# Maximale Anzahl gleichzeitiger Sessions pro Benutzer (älteste wird bei Überschreitung gelöscht)
MAX_SESSIONS_PER_USER=10

# ------------------------------------------------------------------------------
# E-Mail-Benachrichtigungen (SMTP)
# ------------------------------------------------------------------------------
# SMTP-Server für E-Mail-Benachrichtigungen (leer = deaktiviert)
SP5_SMTP_HOST=
SP5_SMTP_PORT=587
SP5_SMTP_USER=
SP5_SMTP_PASSWORD=
# Absender-Adresse (Standard: SP5_SMTP_USER)
SP5_SMTP_FROM=
# TLS-Modus: "true" = STARTTLS (Port 587), "ssl" = Implicit SSL (Port 465)
SP5_SMTP_TLS=true
# Explizit aktivieren/deaktivieren (Standard: automatisch wenn Host gesetzt)
SP5_SMTP_ENABLED=
# Basis-URL für Links in E-Mails (z.B. https://sp5.example.com)
SP5_APP_URL=http://localhost:8000

# ------------------------------------------------------------------------------
# Paket-Ressourcen (normalerweise NICHT setzen — start.sh/Docker setzen sie)
# ------------------------------------------------------------------------------
# Ressourcen-Root für die Pakete sp5api/sp5lib (data/, api/data, alembic).
# start.sh und das Docker-Image setzen das automatisch auf backend/.
# SP5_BACKEND_DIR=
# Pfad zum gebauten Frontend (Standard: SP5_BACKEND_DIR/../frontend/dist).
# SP5_FRONTEND_DIST=
